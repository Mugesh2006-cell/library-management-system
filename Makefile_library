CXX      = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -O2
TARGET   = library_management
SRC      = library_management.cpp

all: $(TARGET)

$(TARGET): $(SRC)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(SRC)

clean:
	rm -f $(TARGET) library_books.dat library_members.dat library_records.dat

run: all
	./$(TARGET)

.PHONY: all clean run
